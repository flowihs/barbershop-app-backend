{
	"buildCommand": "yarn prisma:generate && yarn build && yarn tsc-alias -p tsconfig.build.json",
	"installCommand": "yarn install",
	"outputDirectory": "dist",
	"devCommand": "yarn start:dev",
	"env": [
		"POSTGRES_URL",
		"PRISMA_DATABASE_URL",
		"TELEGRAM_BOT_TOKEN",
		"APPLICATION_PORT",
		"ALLOWED_ORIGIN",
		"COOKIES_SECRET",
		"VERCEL",
		"VERCEL_ENV",
		"VERCEL_URL",
		"NODE_ENV"
	]
}
