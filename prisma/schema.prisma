generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URI")
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum Roles {
  ADMIN
  BARBER
  CLIENT
}

model User {
  id BigInt @id

  firstName   String  @map("first_name")
  username    String?
  description String?
  email       String? @unique

  role Roles @default(CLIENT)

  provisions Provision[]
  bookings   Booking[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Provision {
  id BigInt @id @default(autoincrement())

  title       String
  description String
  price       Int
  image       String

  user   User   @relation(fields: [userId], references: [id])
  userId BigInt @map("user_id")

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId BigInt @map("category_id")

  slots Slot[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("provisions")
}

model Category {
  id BigInt @id @default(autoincrement())

  name String @unique

  provisions Provision[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model Slot {
  id BigInt @id @default(autoincrement())

  time      DateTime
  isBooking Boolean  @default(false) @map("is_booking")

  provision   Provision @relation(fields: [provisionId], references: [id], onDelete: Cascade)
  provisionId BigInt @map("provision_id")

  booking Booking?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isBooking, time, provisionId])
  @@map("slots")
}

model Booking {
  id BigInt @id @default(autoincrement())

  slot   Slot   @relation(fields: [slotId], references: [id])
  slotId BigInt @unique

  user   User   @relation(fields: [userId], references: [id])
  userId BigInt

  status BookingStatus @default(CONFIRMED)
  totalPrice Int?

  cancelledAt DateTime? @map("cancelled_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("bookings")
}
