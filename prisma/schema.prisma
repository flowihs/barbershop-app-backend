generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URI")
}

model User {
  id BigInt @id

  firstName   String  @map("first_name")
  username    String?
  description String?
  email       String? @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}
model Provision {
  id BigInt @id @default(autoincrement())

  title       String
  discription String
  prive       Int
  time        DateTime

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("provisions")
}
