generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URI")
}

model User {
  id BigInt @id

  firstName   String  @map("first_name")
  username    String?
  description String?
  email       String? @unique

  provisions Provision[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Provision {
  id BigInt @id @default(autoincrement())

  title       String
  description String
  price       Int
  image       String

  user   User   @relation(fields: [userId], references: [id])
  userId BigInt

  slots Slot[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("provisions")
}

model Slot {
  id BigInt @id @default(autoincrement())

  time DateTime

  provision Provision @relation(fields: [provisionId], references: [id])
  provisionId BigInt

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("slots")
}
