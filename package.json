{
	"name": "barbershop-app-backend",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build && tsc-alias -p tsconfig.build.json",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "node -r tsconfig-paths/register dist/main",
		"start:dev": "nest start --exec \"node -r tsconfig-paths/register\" --watch",
		"start:debug": "nest start --exec \"node -r tsconfig-paths/register\" --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"prisma:generate": "prisma generate",
		"prisma:push": "prisma db push",
		"prisma:studio": "prisma studio",
		"prisma:migrate": "prisma migrate dev",
		"vercel-build": "yarn prisma:generate && yarn build",
		"postinstall": "prisma generate"
	},
	"dependencies": {
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.3",
		"@nestjs/core": "^11.0.1",
		"@nestjs/mapped-types": "*",
		"@nestjs/platform-express": "^11.1.16",
		"@nestjs/swagger": "^11.2.6",
		"@prisma/client": "5",
		"@telegram-apps/init-data-node": "^2.0.10",
		"@telegram-apps/sdk": "^3.11.8",
		"@upstash/redis": "^1.37.0",
		"argon2": "^0.44.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.4",
		"connect-redis": "^9.0.0",
		"cookie-parser": "^1.4.7",
		"device-detector-js": "^3.0.3",
		"express": "^4.18.2",
		"express-session": "^1.19.0",
		"i18n-iso-countries": "^7.14.0",
		"ioredis": "^5.9.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"swagger-ui-express": "^5.0.1"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.2.0",
		"@eslint/js": "^9.18.0",
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "^5.0.0",
		"@types/express-session": "^1.18.2",
		"@types/geoip-lite": "^1.4.4",
		"@types/jest": "^30.0.0",
		"@types/node": "^22.10.7",
		"@types/supertest": "^6.0.2",
		"@vercel/node": "^5.6.15",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-prettier": "^5.2.2",
		"globals": "^16.0.0",
		"jest": "^30.0.0",
		"prettier": "^3.8.1",
		"prisma": "5",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.16",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.20.0"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": ".",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"src/**/*.(t|j)s"
		],
		"coverageDirectory": "./coverage",
		"testEnvironment": "node",
		"moduleNameMapper": {
			"^@/(.*)$": "<rootDir>/$1"
		}
	}
}
