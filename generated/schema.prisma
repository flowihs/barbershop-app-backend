generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URI")
}

enum Roles {
  ADMIN
  BARBER
  CLIENT
}

model User {
  id BigInt @id

  firstName   String  @map("first_name")
  username    String?
  description String?
  email       String? @unique

  role Roles @default(CLIENT)

  provisions Provision[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Provision {
  id BigInt @id @default(autoincrement())

  title       String
  description String
  price       Int
  image       String

  user   User   @relation(fields: [userId], references: [id])
  userId BigInt

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId BigInt

  slots Slot[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("provisions")
}

model Slot {
  id BigInt @id @default(autoincrement())

  time      DateTime
  isBooking Boolean  @default(false)

  provision   Provision @relation(fields: [provisionId], references: [id])
  provisionId BigInt

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isBooking, time, provisionId])
  @@map("slots")
}

model Category {
  id BigInt @id @default(autoincrement())

  name String

  provision Provision[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}
